<script language="JavaScript">
$(document).ready(function(){
    // Function to set a value in localStorage
    function setLocalStorage(name, value) {
        localStorage.setItem(name, value);
    }

    // Function to get a value from localStorage
    function getLocalStorage(name) {
        return localStorage.getItem(name);
    }

    // Check if the popup should be shown
    var ebrakePopupShown = getLocalStorage("ebrakePopupShown");
    if (!ebrakePopupShown) {
        setTimeout(function() {
            $("#ebrakepop").show();
            $("#popup-box").show();
        }, 5000);
    }

    // Handle form submission
    $("button[name='subscribe']").on('click', function() {
        var email = $("input[name='email']").val();
        $.ajax({
            url: 'https://pca.org/cfc/techDOA.cfc?method=ebrakeSubscription', 
            type: 'POST',
            data: { email: email, list: 'ebrake' },
            success: function(response) {
                $("#popup-box-content").html('<h3 class="pca-white" style="text-align: center;">Thank you for subscribing to PCA\'s FREE e-Brake News newsletter!</h3>');
                setTimeout(function() {
                    $("#ebrakepop").hide();
                }, 5000);
                setLocalStorage("ebrakePopupShown", "true");
            },
            error: function() {
                alert('There was an error processing your request. Please try again.');
            }
        });
    });

    // Handle popup close
    $("#popup-close").on('click', function() {
        $("#ebrakepop").hide();
        setLocalStorage("ebrakePopupShown", "true");
    });

    if (isMobile == '1') {
        var x = document.getElementById("tow");
        var y = document.getElementById("color1");
        x.style.display = "none";
        y.style.display = "none";
        document.getElementById('homebanner').style.minHeight = '300px';
    } else {
        
    };

    $("a").on('click', function(event) {
        if (this.hash !== "") {
            event.preventDefault();
            var hash = this.hash;
            $('html, body').animate({
                scrollTop: $(hash).offset().top
            }, 800, function(){
                window.location.hash = hash;
            });
        } 
    });

    $("button[name='subscribe']").on('click', function() {
        var email = $("input[name='email']").val();
        $.ajax({
            url: 'https://pca.org/cfc/techDOA.cfc?method=ebrakeSubscription', 
            type: 'POST',
            data: { email: email, 
                    list: 'ebrake' 
                  },
            success: function(response) {
                $("#popup-box-content").html('<h3 class="pca-white" style="text-align: center;">Thank you for subscribing to PCA\'s FREE e-Brake News newsletter!</h3>');
                setTimeout(function() {
                    $("#ebrakepop").hide();
                }, 5000);
                setLocalStorage("ebrakePopupShown", "true");
            },
            error: function() {
                alert('There was an error processing your request. Please try again.');
            }
        });
    });

    $("#popup-close").on('click', function() {
        $("#ebrakepop").hide();
        setLocalStorage("ebrakePopupShown", "true");
    });

    setTimeout(function() {
        if (!getLocalStorage("ebrakePopupShown")) {
            $("#ebrakepop").show();
            $("#popup-box").show();
        }
    }, 5000);
});
</script>
    
   
